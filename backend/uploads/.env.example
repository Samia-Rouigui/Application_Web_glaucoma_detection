# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# Clé secrète JWT (obligatoire en production — utiliser une longue chaîne aléatoire)
JWT_SECRET=change_this_to_a_strong_random_secret

# Clé API OpenAI (obligatoire pour le chatbot)
OPENAI_API_KEY=sk-...votre_cle_ici...

# URL du service Deep Learning (ne pas modifier sauf configuration custom)
DL_SERVICE_URL=http://localhost:8001/analyze/

# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
